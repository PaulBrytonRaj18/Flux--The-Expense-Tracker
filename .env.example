# Flux — Environment Configuration
# Copy to .env and customize as needed.

# Supabase PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Supabase project URL (REQUIRED — used for token verification)
SUPABASE_URL=https://[REF].supabase.co

# Supabase anon/public API key (REQUIRED — used for token verification)
SUPABASE_ANON_KEY=your-anon-key-from-supabase

# Environment (production or development)
ENV=production

# Port for the server (Cloud Run: 8080, Local dev: 8000)
PORT=8080

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Path to built frontend assets (auto-detected if not set)
# STATIC_DIR=/app/frontend/dist
